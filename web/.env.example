# FlyFast Frontend Environment Variables

# API backend URL for server-side calls (required)
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://localhost:8000
INTERNAL_API_TOKEN=

# Site URL for SEO/sitemap (defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://flyfast.app

# Last zones data update (ISO date, shown in footer)
NEXT_PUBLIC_ZONES_UPDATED_AT=2026-03-16

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
