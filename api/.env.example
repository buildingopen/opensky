# Required in production unless REQUIRE_GEMINI_KEY=false
GEMINI_API_KEY=

# API networking
ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=false
SKYROUTE_PROXY=

# Rate limiting
RATE_LIMIT_PER_HOUR=10
RATE_LIMIT_WHITELIST=
RATE_LIMIT_PREFIX=opensky:ratelimit
REDIS_URL=

# Optional API keys (higher quota for trusted clients)
# API_KEYS=key1,key2
# API_KEY_QUOTA=100

# Parser reliability
GEMINI_TIMEOUT_SECONDS=10
GEMINI_MAX_RETRIES=2
REQUIRE_GEMINI_KEY=true
